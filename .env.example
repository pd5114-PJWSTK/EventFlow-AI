APP_NAME=EventFlow
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_USER=eventflow
POSTGRES_PASSWORD=eventflow
POSTGRES_DB=eventflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://eventflow:eventflow@postgres:5432/eventflow

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=1440
DEMO_ADMIN_ENABLED=true
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123
AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
API_TEST_JOBS_ENABLED=true

READY_CHECK_EXTERNALS=true
CELERY_ALWAYS_EAGER=false

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-08-01-preview
AZURE_DEPLOYMENT_LLM=gpt-4.1-mini

AI_AZURE_LLM_ENABLED=false
AI_AZURE_LLM_TIMEOUT_SECONDS=20
AI_AZURE_LLM_MAX_RETRIES=2
AI_AZURE_LLM_RETRY_BACKOFF_SECONDS=0.5
AI_AZURE_LLM_RATE_LIMIT_PER_MINUTE=5
AI_AZURE_LLM_MAX_INPUT_TOKENS=1200
AI_AZURE_LLM_MAX_OUTPUT_TOKENS=500
AI_AZURE_LLM_MAX_DAILY_SPEND_USD=3.0
AI_AZURE_LLM_INPUT_COST_PER_1K_USD=0.0004
AI_AZURE_LLM_OUTPUT_COST_PER_1K_USD=0.0016

ML_MODELS_DIR=./models
ML_MIN_TRAINING_SAMPLES=3
ML_TRAIN_TEST_SPLIT_RATIO=0.2
ML_TRAINING_RANDOM_SEED=42
ML_SYNTHETIC_SAMPLES_PER_REAL=8
ML_HARDENING_REQUIRED_REAL_SAMPLES=60
ML_HARDENING_TRAIN_SAMPLES=50
ML_HARDENING_TEST_SAMPLES=10
ML_PLAN_GUARDRAIL_CONFIDENCE_MIN=0.60
ML_PLAN_GUARDRAIL_OOD_MAX=0.55
ML_PLAN_GUARDRAIL_HIGH_RISK_MAX=0.70
ML_RETRAIN_ENABLED=true
ML_RETRAIN_SCHEDULE_MINUTES=360
ML_RETRAIN_ACTIVATION_MIN_SAMPLES=3
ML_RETRAIN_ACTIVATION_MIN_R2_IMPROVEMENT=0.0
ML_RETRAIN_ACTIVATION_MAX_MAE_RATIO=1.0
